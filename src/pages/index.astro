---
import "../styles/global.css";
import t from "../i18n/index.ts";
---

<html lang={t.lang} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{t.site.title}</title>
    <script is:inline>
      if (localStorage.getItem('sql-lab-theme') === 'light') document.documentElement.classList.add('light');
    </script>
  </head>

  <body class="bg-[#0f172a] text-slate-300 font-sans min-h-screen">
    <!-- Theme toggle (top right) -->
    <div class="fixed top-4 right-4 z-50 flex items-center gap-2">
      <svg class="w-3.5 h-3.5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
      </svg>
      <div id="btn-theme" class="theme-switch" aria-label={t.nav.themeToggle}></div>
      <svg class="w-3.5 h-3.5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>
    </div>

    <div class="min-h-screen flex items-center justify-center p-6">
      <div class="max-w-4xl w-full">
        <div class="text-center mb-12">
          <div class="inline-flex items-center gap-3 mb-6">
            <div class="w-12 h-12 bg-emerald-500/20 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4" />
              </svg>
            </div>
          </div>
          <h1 class="text-4xl md:text-5xl font-black text-white tracking-tight mb-4">
            SQL<span class="text-emerald-400">_Lab</span>
          </h1>
          <p class="text-lg text-slate-400 italic">{t.site.subtitle}</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
          <div class="space-y-6">
            <div class="p-6 bg-slate-900/50 rounded-2xl border border-white/5">
              <h2 class="text-sm font-bold text-emerald-400 uppercase tracking-widest mb-3">{t.welcome.whatIsSql}</h2>
              <p class="text-sm text-slate-400 leading-relaxed text-justify" set:html={t.welcome.sqlDescription}></p>
            </div>

            <div class="p-6 bg-slate-900/50 rounded-2xl border border-white/5">
              <h2 class="text-sm font-bold text-cyan-400 uppercase tracking-widest mb-3">{t.welcome.relationalDb}</h2>
              <p class="text-sm text-slate-400 leading-relaxed text-justify" set:html={t.welcome.relationalDescription}></p>
            </div>
          </div>

          <div class="space-y-6">
            <div class="p-6 bg-slate-900/50 rounded-2xl border border-white/5">
              <h2 class="text-sm font-bold text-white uppercase tracking-widest mb-3">{t.welcome.aboutExercises}</h2>
              <p class="text-sm text-slate-400 leading-relaxed mb-3 text-justify" set:html={t.welcome.aboutDescription1}></p>
              <p class="text-sm text-slate-400 leading-relaxed text-justify" set:html={t.welcome.aboutDescription2}></p>
            </div>

            <div class="grid grid-cols-3 gap-4 text-center p-6 bg-slate-900/50 rounded-2xl border border-white/5">
              <div>
                <p class="text-2xl font-black text-white">87</p>
                <p class="text-[10px] text-slate-500 uppercase tracking-widest">{t.welcome.exercises}</p>
              </div>
              <div>
                <p class="text-2xl font-black text-white">10</p>
                <p class="text-[10px] text-slate-500 uppercase tracking-widest">{t.welcome.tables}</p>
              </div>
              <div>
                <p class="text-2xl font-black text-white">9k+</p>
                <p class="text-[10px] text-slate-500 uppercase tracking-widest">{t.welcome.records}</p>
              </div>
            </div>

            <a href={`${import.meta.env.BASE_URL}lessons/ddl`} class="block w-full px-8 py-3 bg-emerald-600 hover:bg-emerald-500 text-white font-bold rounded-xl transition-all shadow-lg shadow-emerald-500/20 text-sm uppercase tracking-widest text-center">
              {t.welcome.start}
            </a>

            <button id="btn-reset-progress" class="hidden w-full px-6 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-400 text-xs rounded-xl transition-all border border-white/10 uppercase tracking-widest">
              {t.welcome.resetProgress}
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Reset confirmation modal -->
    <div id="reset-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-sm">
      <div class="bg-[#1e293b] border border-white/10 rounded-2xl p-6 max-w-sm w-full mx-4 shadow-2xl">
        <p class="text-white font-bold mb-2">{t.modal.resetTitle}</p>
        <p class="text-sm text-slate-400 mb-5">{t.modal.resetMessage}</p>
        <div class="flex gap-3 justify-end">
          <button id="reset-cancel" class="px-4 py-2 text-sm text-slate-400 hover:text-white transition">{t.modal.cancel}</button>
          <button id="reset-confirm" class="px-4 py-2 bg-red-600 hover:bg-red-500 text-white text-sm font-bold rounded-lg transition">{t.modal.reset}</button>
        </div>
      </div>
    </div>

    <script>
      const saved = localStorage.getItem('sql-lab-completed');
      const completed = saved ? JSON.parse(saved) : [];

      if (completed.length > 0) {
        document.getElementById('btn-reset-progress')!.classList.remove('hidden');
      }

      document.getElementById('btn-reset-progress')!.addEventListener('click', () => {
        document.getElementById('reset-modal')!.classList.remove('hidden');
      });

      document.getElementById('reset-cancel')!.addEventListener('click', () => {
        document.getElementById('reset-modal')!.classList.add('hidden');
      });

      document.getElementById('reset-modal')!.addEventListener('click', (e) => {
        if (e.target === document.getElementById('reset-modal')) {
          document.getElementById('reset-modal')!.classList.add('hidden');
        }
      });

      document.getElementById('reset-confirm')!.addEventListener('click', () => {
        localStorage.removeItem('sql-lab-completed');
        document.getElementById('reset-modal')!.classList.add('hidden');
        document.getElementById('btn-reset-progress')!.classList.add('hidden');
      });

      // Theme toggle
      const savedTheme = localStorage.getItem('sql-lab-theme') || 'dark';
      if (savedTheme === 'light') document.documentElement.classList.add('light');

      document.getElementById('btn-theme')!.onclick = () => {
        const isLight = document.documentElement.classList.toggle('light');
        localStorage.setItem('sql-lab-theme', isLight ? 'light' : 'dark');
      };
    </script>
  </body>
</html>
