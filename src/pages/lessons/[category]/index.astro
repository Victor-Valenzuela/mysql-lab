---
import "../../../styles/global.css";
import exercisesData from "../../../data/exercises.json";
import Header from "../../../components/Header.astro";
import Sidebar from "../../../components/Sidebar.astro";
import MobileMenu from "../../../components/MobileMenu.astro";
import t from "../../../i18n/index.ts";
import intros from "../../../i18n/intros-es.json";

export function getStaticPaths() {
  return exercisesData.categories.map((cat) => ({
    params: { category: cat.id },
    props: { category: cat, allCategories: exercisesData.categories },
  }));
}

const { category: currentCategory, allCategories } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const intro = (intros as any)[currentCategory.id];
const firstExercise = currentCategory.exercises[0];
---

<html lang={t.lang} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>SQL Lab — {currentCategory.title}</title>
    <script is:inline>
      if (localStorage.getItem('sql-lab-theme') === 'light') document.documentElement.classList.add('light');
    </script>
  </head>

  <body class="bg-[#0f172a] text-slate-300 font-sans min-h-screen">
    <Header base={base} showMenu={true} />
    <MobileMenu base={base} currentCategoryId={currentCategory.id} />

    <div class="flex pt-14">
      <aside class="hidden lg:block w-72 h-[calc(100vh-56px)] overflow-y-auto fixed bg-[#0a0f1e] border-r border-white/5 p-6">
        <Sidebar base={base} currentCategoryId={currentCategory.id} />
      </aside>

      <main class="w-full lg:ml-72 p-6 lg:p-10">
        <div class="w-full">
          <div class="mb-2">
            <span class="text-[10px] font-bold text-emerald-400 uppercase tracking-widest">{currentCategory.title}</span>
          </div>

          <h2 class="text-3xl lg:text-4xl font-black text-white tracking-tight mb-6">{intro.title}</h2>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-10">
            <div class="space-y-4">
              {intro.paragraphs.map((p: string) => (
                <p class="text-sm lg:text-base text-slate-400 leading-relaxed" set:html={p
                  .replace(/\*\*(.+?)\*\*/g, '<strong class="text-white font-semibold">$1</strong>')
                  .replace(/`([^`]+)`/g, '<code class="bg-white/10 px-1.5 py-0.5 rounded text-cyan-300 text-[11px] font-mono">$1</code>')
                }></p>
              ))}
            </div>

            <div class="p-5 bg-slate-900/50 rounded-2xl border border-white/5 h-fit">
              <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">{t.intro.exercisesInSection}</p>
              <div class="space-y-1">
                {currentCategory.exercises.map((ex) => (
                  <p class="text-sm text-slate-400">{ex.id}. {ex.title}</p>
                ))}
              </div>
            </div>
          </div>

          <div class="max-w-md mx-auto">
            <a href={`${base}lessons/${currentCategory.id}/${firstExercise.id}`} class="block w-full px-8 py-3 bg-emerald-600 hover:bg-emerald-500 text-white font-bold rounded-xl transition-all shadow-lg shadow-emerald-500/20 text-sm uppercase tracking-widest text-center">
              {t.intro.startExercises}
            </a>
          </div>
        </div>
      </main>
    </div>

    <script>
      // Theme
      const savedTheme = localStorage.getItem('sql-lab-theme') || 'dark';
      if (savedTheme === 'light') document.documentElement.classList.add('light');

      document.getElementById('btn-theme')!.onclick = () => {
        const isLight = document.documentElement.classList.toggle('light');
        localStorage.setItem('sql-lab-theme', isLight ? 'light' : 'dark');
      };

      // Mobile menu
      document.getElementById('btn-menu')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')!.classList.remove('hidden');
      });
      document.getElementById('menu-backdrop')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')!.classList.add('hidden');
      });

      // Progress
      const completed = JSON.parse(localStorage.getItem('sql-lab-completed') || '[]');
      const total = 87;
      const pct = (completed.length / total) * 100;
      const progressBar = document.getElementById('progress-bar');
      const progressText = document.getElementById('progress-text');
      if (progressBar) progressBar.style.width = `${pct}%`;
      if (progressText) progressText.textContent = `${completed.length} / ${total}`;
    </script>
  </body>
</html>
