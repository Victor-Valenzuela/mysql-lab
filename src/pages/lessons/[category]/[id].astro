---
import "../../../styles/global.css";
import { exercisesData } from "../../../i18n/index.ts";
import t from "../../../i18n/index.ts";

export function getStaticPaths() {
  return exercisesData.categories.flatMap((cat) =>
    cat.exercises.map((ex) => ({
      params: { category: cat.id, id: String(ex.id) },
      props: { exercise: ex, category: cat, allCategories: exercisesData.categories },
    }))
  );
}

const { category, id } = Astro.params;
const { exercise, category: currentCategory, allCategories } = Astro.props;

const allExercises = allCategories.flatMap((cat) =>
  cat.exercises.map((ex) => ({ ...ex, categoryId: cat.id, categoryTitle: cat.title }))
);
const currentIndex = allExercises.findIndex((ex) => ex.id === exercise.id);
const prevExercise = currentIndex > 0 ? allExercises[currentIndex - 1] : null;
const nextExercise = currentIndex < allExercises.length - 1 ? allExercises[currentIndex + 1] : null;

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const prevUrl = prevExercise ? `${base}lessons/${prevExercise.categoryId}/${prevExercise.id}` : null;
// If next exercise is in a different section, link to that section's intro
// If no next exercise (last one), link to completion page
const nextUrl = nextExercise
  ? (nextExercise.categoryId !== currentCategory.id
    ? `${base}lessons/${nextExercise.categoryId}`
    : `${base}lessons/${nextExercise.categoryId}/${nextExercise.id}`)
  : `${base}lessons/complete`;

const isSelectExercise = /^\s*(SELECT|WITH)\b/i.test(exercise.expected);
---

<html lang={t.lang} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>SQL Lab — {exercise.title}</title>
    <script is:inline>
      if (localStorage.getItem('sql-lab-theme') === 'light') document.documentElement.classList.add('light');
    </script>
  </head>

  <body class="bg-[#0f172a] text-slate-300 font-sans min-h-screen">
    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-[#0f172a]/95 backdrop-blur border-b border-white/5">
      <div class="px-4 lg:px-6 py-3 flex items-center justify-between">
        <!-- Left: hamburger/logo -->
        <div class="flex items-center gap-3 min-w-0">
          <button id="btn-menu" class="lg:hidden w-8 h-8 flex items-center justify-center text-slate-400 hover:text-white transition">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
          <a href={base} class="hidden lg:flex items-center gap-3 hover:opacity-80 transition">
            <div class="w-8 h-8 bg-emerald-500/20 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4" />
              </svg>
            </div>
            <h1 class="text-lg font-bold text-white tracking-tight">SQL<span class="text-emerald-400">_Lab</span></h1>
          </a>
          <span class="lg:hidden text-sm font-bold text-white">SQL<span class="text-emerald-400">_Lab</span></span>
        </div>
        <!-- Center: progress -->
        <div class="flex items-center gap-2 lg:gap-3">
          <span id="progress-text" class="text-[10px] sm:text-xs text-slate-500 font-mono">0 / {allExercises.length}</span>
          <div class="w-12 sm:w-24 lg:w-32 h-1.5 bg-slate-800 rounded-full overflow-hidden">
            <div id="progress-bar" class="h-full bg-emerald-500 rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
        </div>
        <!-- Right: theme toggle -->
        <div class="flex items-center gap-2">
          <svg class="w-3.5 h-3.5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
          <div id="btn-theme" class="theme-switch" aria-label="Cambiar tema"></div>
          <svg class="w-3.5 h-3.5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
        </div>
      </div>
    </header>

    <!-- Mobile sidebar overlay -->
    <div id="mobile-menu" class="hidden fixed inset-0 z-[90] lg:hidden">
      <div id="menu-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
      <aside class="absolute left-0 top-0 bottom-0 w-72 bg-[#0a0f1e] border-r border-white/5 overflow-y-auto p-6 pt-6">
        <a href={base} class="flex items-center gap-3 mb-6 px-3 py-2 rounded-lg hover:bg-white/5 transition">
          <div class="w-6 h-6 bg-emerald-500/20 rounded flex items-center justify-center">
            <svg class="w-3 h-3 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3" />
            </svg>
          </div>
          <span class="text-xs text-slate-300 font-medium">{t.nav.backToStart}</span>
        </a>
        <nav class="space-y-2">
          {allCategories.map((cat) => (
            <details open={cat.id === currentCategory.id} class="group">
              <summary class="cursor-pointer text-[10px] font-bold text-slate-500 uppercase tracking-widest px-2 py-1.5 rounded-md hover:bg-white/5 hover:text-slate-300 transition flex items-center gap-1">
                <span class="text-[8px] text-slate-600 group-open:rotate-90 transition-transform hover:scale-150">▶</span>
                <a href={`${base}lessons/${cat.id}`} class="section-link hover:text-emerald-400 hover:underline underline-offset-2 transition" onclick="event.stopPropagation()">{cat.title}</a>
              </summary>
              <div class="space-y-1 mt-1 ml-2">
                {cat.exercises.map((ex) => (
                  <a
                    href={`${base}lessons/${cat.id}/${ex.id}`}
                    data-exercise-id={ex.id}
                    data-category-id={cat.id}
                    class:list={[
                      "nav-btn w-full text-left px-3 py-1.5 text-xs rounded-md hover:bg-white/5 hover:text-white transition-all flex items-center gap-2",
                      ex.id === exercise.id ? "bg-emerald-500/10 text-emerald-400" : "text-slate-400"
                    ]}
                  >
                    <span class="status-dot w-2 h-2 rounded-full bg-slate-700 flex-shrink-0"></span>
                    <span class="truncate">{ex.id}. {ex.title}</span>
                  </a>
                ))}
              </div>
            </details>
          ))}
        </nav>
      </aside>
    </div>

    <div class="flex pt-14">
      <!-- Desktop Sidebar -->
      <aside class="hidden lg:block w-72 h-[calc(100vh-56px)] overflow-y-auto fixed bg-[#0a0f1e] border-r border-white/5 p-6">
        <nav class="space-y-2">
          {allCategories.map((cat) => (
            <details open={cat.id === currentCategory.id} class="group">
              <summary class="cursor-pointer text-[10px] font-bold text-slate-500 uppercase tracking-widest px-2 py-1.5 rounded-md hover:bg-white/5 hover:text-slate-300 transition flex items-center gap-1">
                <span class="text-[8px] text-slate-600 group-open:rotate-90 transition-transform hover:scale-150">▶</span>
                <a href={`${base}lessons/${cat.id}`} class="section-link hover:text-emerald-400 hover:underline underline-offset-2 transition" onclick="event.stopPropagation()">{cat.title}</a>
              </summary>
              <div class="space-y-1 mt-1 ml-2">
                {cat.exercises.map((ex) => (
                  <a
                    href={`${base}lessons/${cat.id}/${ex.id}`}
                    data-exercise-id={ex.id}
                    data-category-id={cat.id}
                    class:list={[
                      "nav-btn w-full text-left px-3 py-1.5 text-xs rounded-md hover:bg-white/5 hover:text-white transition-all flex items-center gap-2",
                      ex.id === exercise.id ? "bg-emerald-500/10 text-emerald-400" : "text-slate-400"
                    ]}
                  >
                    <span class="status-dot w-2 h-2 rounded-full bg-slate-700 flex-shrink-0"></span>
                    <span class="truncate">{ex.id}. {ex.title}</span>
                  </a>
                ))}
              </div>
            </details>
          ))}
        </nav>
      </aside>

      <!-- Main Content -->
      <main class="w-full lg:ml-72 p-4 lg:p-10 max-w-6xl">
        <!-- Exercise Header -->
        <div class="mb-6">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-[10px] font-bold text-emerald-400 uppercase tracking-widest">{currentCategory.title}</span>
            <span class="text-[10px] font-mono text-slate-600">{currentIndex + 1} / {allExercises.length}</span>
          </div>
          <h2 class="text-xl lg:text-2xl font-bold text-white tracking-tight mb-3">{exercise.title}</h2>

          {exercise.theory && (
            <div class="mb-4 p-4 bg-slate-900/50 rounded-xl border border-white/5">
              <div class="text-xs lg:text-sm text-slate-300 leading-relaxed whitespace-pre-wrap theory-block text-justify" set:html={exercise.theory
                .replace(/\*\*(.+?)\*\*/g, '<strong class="text-white font-semibold">$1</strong>')
                .replace(/`([^`]+)`/g, '<code class="bg-white/10 px-1.5 py-0.5 rounded text-cyan-300 text-[11px] font-mono">$1</code>')
              }></div>
            </div>
            <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">{t.exercise.task}</span>
          )}

          <p class="text-sm text-slate-400 leading-relaxed whitespace-pre-line text-justify">{exercise.description}</p>
        </div>

        <!-- Schema Reference (only for SELECT exercises) -->
        {isSelectExercise && (
          <details class="mb-6 group">
            <summary class="cursor-pointer text-xs font-bold text-cyan-400 uppercase tracking-widest hover:text-cyan-300 transition">
              {t.exercise.schemaToggle}
            </summary>
            <div class="mt-3 p-4 bg-slate-900/50 rounded-xl border border-white/5 font-mono text-[11px] text-slate-400 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 max-h-80 overflow-y-auto">
              <div><p class="text-emerald-400 font-bold mb-1">patients</p><p>id, first_name, last_name, birth_date, gender, phone, email, address, insurance_number</p></div>
              <div><p class="text-emerald-400 font-bold mb-1">doctors</p><p>id, first_name, last_name, specialization, department_id, hire_date, phone, email</p></div>
              <div><p class="text-emerald-400 font-bold mb-1">departments</p><p>id, name, floor, phone</p></div>
              <div><p class="text-emerald-400 font-bold mb-1">appointments</p><p>id, patient_id, doctor_id, appointment_date, status, notes</p></div>
              <div><p class="text-emerald-400 font-bold mb-1">diagnoses</p><p>id, appointment_id, diagnosis_code, description, severity</p></div>
              <div><p class="text-emerald-400 font-bold mb-1">medications</p><p>id, name, category, manufacturer, price</p></div>
              <div><p class="text-emerald-400 font-bold mb-1">prescriptions</p><p>id, diagnosis_id, medication_id, dosage, frequency, start_date, end_date</p></div>
              <div><p class="text-emerald-400 font-bold mb-1">rooms</p><p>id, room_number, department_id, capacity, room_type</p></div>
              <div><p class="text-emerald-400 font-bold mb-1">admissions</p><p>id, patient_id, room_id, admission_date, discharge_date, reason</p></div>
              <div><p class="text-emerald-400 font-bold mb-1">invoices</p><p>id, patient_id, department_id, amount, invoice_date, status</p></div>
            </div>
          </details>
        )}

        <!-- Editor area -->
        <div class="relative">
          <!-- Desktop hint panel (absolute right) -->
          <div class="hidden xl:block absolute top-0 left-full ml-6">
            <div id="hint-panel-desktop" class="sticky top-20 w-100">
              <div id="hint-box-desktop" class="hidden p-5 bg-amber-900/10 border border-amber-500/20 rounded-xl">
                <p class="text-xs text-amber-400 font-bold uppercase mb-2">💡 {t.exercise.hint}</p>
                <ul id="hint-text-desktop" class="text-sm text-amber-200/80 leading-relaxed space-y-1 list-disc list-inside"></ul>
              </div>
              <div id="hint-placeholder-desktop" class="p-5 bg-slate-900/30 border border-white/5 rounded-xl text-center">
                <p class="text-xs text-slate-400 italic">{t.exercise.hintPlaceholder}</p>
              </div>
            </div>
          </div>

          <!-- SQL Editor -->
          <div class="mb-4 rounded-xl overflow-hidden border border-white/10 bg-[#1a1f2e]">
            <div class="flex items-center justify-between px-4 py-2 bg-white/5 border-b border-white/5">
              <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">MySQL Query</span>
              <div class="flex gap-1.5">
                <div class="w-2 h-2 rounded-full bg-red-500/50"></div>
                <div class="w-2 h-2 rounded-full bg-yellow-500/50"></div>
                <div class="w-2 h-2 rounded-full bg-green-500/50"></div>
              </div>
            </div>
            <div id="editor" class="min-h-[140px] lg:min-h-[160px]"></div>
          </div>

          <!-- Action Buttons -->
          <!-- Mobile: row 1 (3 cols) + row 2 (around) -->
          <!-- Desktop: single row with all buttons -->
          <div class:list={["grid lg:flex lg:items-center gap-2 lg:gap-3 mb-2 lg:mb-6", isSelectExercise ? "grid-cols-3" : "grid-cols-2"]}>
            {isSelectExercise && (
              <button id="btn-run" class="px-4 lg:px-5 py-2 lg:py-2.5 bg-emerald-600 hover:bg-emerald-500 text-white text-xs lg:text-sm font-bold rounded-lg transition-all shadow-lg shadow-emerald-500/20">
                <svg class="w-3.5 h-3.5 inline" fill="currentColor" viewBox="0 0 20 20"><path d="M6.3 2.8A1.5 1.5 0 004 4.1v11.8a1.5 1.5 0 002.3 1.3l9.2-5.9a1.5 1.5 0 000-2.6L6.3 2.8z"/></svg> {t.exercise.run}
              </button>
            )}
            <button id="btn-validate" class="px-4 lg:px-5 py-2 lg:py-2.5 bg-cyan-600 hover:bg-cyan-500 text-white text-xs lg:text-sm font-bold rounded-lg transition-all shadow-lg shadow-cyan-500/20">
              <svg class="w-3.5 h-3.5 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg> {t.exercise.validate}
            </button>
            <button id="btn-hint" class="px-3 lg:px-4 py-2 lg:py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-300 text-xs lg:text-sm rounded-lg transition-all border border-white/10">
              💡 {t.exercise.hint}
            </button>
            {isSelectExercise && (
              <button id="btn-reset" class="hidden lg:block px-4 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-300 text-sm rounded-lg transition-all border border-white/10">
                <svg class="w-3.5 h-3.5 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg> {t.exercise.resetDb}
              </button>
            )}
            <div class="hidden lg:block flex-1"></div>
            <div class="hidden lg:flex items-center gap-2">
              {prevUrl ? (
                <a href={prevUrl} class="px-3 py-2 bg-slate-800 hover:bg-slate-700 text-slate-400 text-sm rounded-lg border border-white/10"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></a>
              ) : (
                <span class="px-3 py-2 bg-slate-800/50 text-slate-600 text-sm rounded-lg border border-white/5 cursor-not-allowed"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></span>
              )}
              {nextUrl ? (
                <a id="btn-next" href={nextUrl} data-next-url={nextUrl} class="px-3 py-2 bg-slate-800/50 text-slate-600 text-sm rounded-lg border border-white/5 cursor-not-allowed pointer-events-none"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
              ) : (
                <span class="px-3 py-2 bg-slate-800/50 text-slate-600 text-sm rounded-lg border border-white/5 cursor-not-allowed"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
              )}
            </div>
          </div>
          <!-- Mobile-only second row -->
          <div class="flex lg:hidden items-center justify-around gap-2 mb-6">
            {isSelectExercise && (
              <button id="btn-reset-mobile" class="px-3 py-2 bg-slate-800 hover:bg-slate-700 text-slate-300 text-xs rounded-lg transition-all border border-white/10">
                <svg class="w-3.5 h-3.5 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg> {t.exercise.resetDb}
              </button>
            )}
            <div class="flex items-center gap-2">
              {prevUrl ? (
                <a href={prevUrl} class="px-3 py-2 bg-slate-800 hover:bg-slate-700 text-slate-400 text-sm rounded-lg border border-white/10"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></a>
              ) : (
                <span class="px-3 py-2 bg-slate-800/50 text-slate-600 text-sm rounded-lg border border-white/5 cursor-not-allowed"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></span>
              )}
              {nextUrl ? (
                <a id="btn-next-mobile" href={nextUrl} data-next-url={nextUrl} class="px-3 py-2 bg-slate-800/50 text-slate-600 text-sm rounded-lg border border-white/5 cursor-not-allowed pointer-events-none"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>
              ) : (
                <span class="px-3 py-2 bg-slate-800/50 text-slate-600 text-sm rounded-lg border border-white/5 cursor-not-allowed"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
              )}
            </div>
          </div>

          <!-- Mobile hint (inline, below buttons) -->
          <div id="hint-box-mobile" class="hidden xl:hidden mb-6 p-4 bg-amber-900/10 border border-amber-500/20 rounded-xl">
            <p class="text-xs text-amber-400 font-bold uppercase mb-2">💡 {t.exercise.hint}</p>
            <ul id="hint-text-mobile" class="text-sm text-amber-200/80 leading-relaxed space-y-1 list-disc list-inside"></ul>
          </div>

          <!-- Feedback -->
          <div id="feedback" class="hidden mb-6 p-4 rounded-xl border">
            <p id="feedback-text" class="text-sm font-medium"></p>
          </div>

          <!-- Results Table -->
          <div id="results-container" class="hidden">
            <div class="flex items-center justify-between mb-3">
              <p class="text-xs font-bold text-slate-500 uppercase tracking-widest">{t.exercise.result}</p>
              <p id="row-count" class="text-xs text-slate-600 font-mono"></p>
            </div>
            <div class="overflow-x-auto rounded-xl border border-white/10 bg-slate-900/50">
              <table id="results-table" class="w-full text-xs font-mono">
                <thead id="results-head" class="bg-white/5 text-emerald-400 uppercase tracking-wider"></thead>
                <tbody id="results-body" class="text-slate-300"></tbody>
              </table>
            </div>
          </div>

          <!-- Loading -->
          <div id="loading" class="hidden text-center py-20">
            <div class="inline-block w-8 h-8 border-2 border-emerald-500/30 border-t-emerald-500 rounded-full animate-spin"></div>
            <p class="mt-4 text-sm text-slate-500">{t.exercise.loading}</p>
          </div>
        </div>
      </main>
    </div>

    <!-- Skip confirmation modal -->
    <div id="skip-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-sm">
      <div class="bg-[#1e293b] border border-white/10 rounded-2xl p-6 max-w-sm w-full mx-4 shadow-2xl">
        <p class="text-white font-bold mb-2">{t.modal.skipTitle}</p>
        <p class="text-sm text-slate-400 mb-5">{t.modal.skipMessage}</p>
        <div class="flex gap-3 justify-end">
          <button id="modal-cancel" class="px-4 py-2 text-sm text-slate-400 hover:text-white transition">{t.modal.cancel}</button>
          <a id="modal-confirm" href="#" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-bold rounded-lg transition">{t.modal.continue}</a>
        </div>
      </div>
    </div>

    <script define:vars={{ exerciseHint: exercise.hint, exerciseExpected: exercise.expected, totalExercises: allExercises.length, exerciseId: exercise.id, isSelect: isSelectExercise, currentCategoryId: currentCategory.id, nextCategoryId: nextExercise?.categoryId || null, i18n: { correct: t.exercise.correct, incorrect: t.exercise.incorrect, loadError: t.exercise.loadError, rows: t.exercise.rows, moreRows: t.exercise.moreRows } }}>
      window.__EXERCISE__ = {
        hint: exerciseHint,
        expected: exerciseExpected,
        total: totalExercises,
        id: exerciseId,
        isSelect: isSelect,
        categoryId: currentCategoryId,
        nextCategoryId: nextCategoryId,
      };
      window.__I18N__ = i18n;
    </script>

    <script>
      import { initDatabase, executeQuery, validateQuery, resetDatabase } from '../../../lib/sql-engine';
      import { EditorView, keymap } from '@codemirror/view';
      import { EditorState } from '@codemirror/state';
      import { sql } from '@codemirror/lang-sql';
      import { oneDark } from '@codemirror/theme-one-dark';
      import { basicSetup } from 'codemirror';

      const exerciseData = (window as any).__EXERCISE__;
      let editor: EditorView;
      let dbReady = false;
      let currentSolved = false;

      const completed = new Set<number>(JSON.parse(localStorage.getItem('sql-lab-completed') || '[]'));
      currentSolved = completed.has(exerciseData.id);

      // DOM
      const loading = document.getElementById('loading')!;
      const feedback = document.getElementById('feedback')!;
      const feedbackText = document.getElementById('feedback-text')!;
      const resultsContainer = document.getElementById('results-container')!;
      const resultsHead = document.getElementById('results-head')!;
      const resultsBody = document.getElementById('results-body')!;
      const rowCount = document.getElementById('row-count')!;
      const progressBar = document.getElementById('progress-bar')!;
      const progressText = document.getElementById('progress-text')!;
      const btnNext = document.getElementById('btn-next') as HTMLAnchorElement | null;
      const skipModal = document.getElementById('skip-modal')!;
      const modalCancel = document.getElementById('modal-cancel')!;
      const modalConfirm = document.getElementById('modal-confirm') as HTMLAnchorElement;
      const mobileMenu = document.getElementById('mobile-menu')!;
      const menuBackdrop = document.getElementById('menu-backdrop')!;

      // Mobile menu
      document.getElementById('btn-menu')!.onclick = () => mobileMenu.classList.remove('hidden');
      menuBackdrop.onclick = () => mobileMenu.classList.add('hidden');

      async function init() {
        loading.classList.remove('hidden');
        initEditor();

        try {
          const baseUrl = import.meta.env.BASE_URL || '/';
          await initDatabase(baseUrl);
          dbReady = true;
          loading.classList.add('hidden');
        } catch (err: any) {
          loading.innerHTML = `<p class="text-red-400 text-sm">${(window as any).__I18N__.loadError} ${err.message}</p>`;
          console.error(err);
        }

        updateProgress();
        updateNavDots();
        updateNextButton();
      }

      function initEditor() {
        const parent = document.getElementById('editor')!;
        editor = new EditorView({
          state: EditorState.create({
            doc: '',
            extensions: [
              basicSetup,
              sql(),
              oneDark,
              EditorView.theme({
                '&': { fontSize: '13px', fontFamily: "'JetBrains Mono', monospace" },
                '.cm-content': { padding: '12px' },
                '.cm-gutters': { background: 'transparent', border: 'none' }
              }),
              keymap.of([{
                key: 'Ctrl-Enter',
                run: () => {
                  if (exerciseData.isSelect) runQuery();
                  else validateCurrentQuery();
                  return true;
                }
              }])
            ]
          }),
          parent
        });
      }

      function runQuery() {
        if (!dbReady) return;
        const userQuery = editor.state.doc.toString().trim();
        if (!userQuery) return;
        const result = executeQuery(userQuery);
        showResults(result);
        if (result.error) showFeedback(false, `Error: ${result.error}`);
        else feedback.classList.add('hidden');
      }

      function validateCurrentQuery() {
        if (!dbReady) return;
        const userQuery = editor.state.doc.toString().trim();
        if (!userQuery) return;
        const validation = validateQuery(userQuery, exerciseData.expected);
        if (exerciseData.isSelect) showResults(validation.userResult);
        showFeedback(validation.correct, validation.correct
          ? (window as any).__I18N__.correct
          : validation.message || (window as any).__I18N__.incorrect
        );
        if (validation.correct && !currentSolved) {
          currentSolved = true;
          completed.add(exerciseData.id);
          localStorage.setItem('sql-lab-completed', JSON.stringify([...completed]));
          updateProgress();
          updateNavDots();
          updateNextButton();
        }
      }

      function showResults(result: any) {
        if (result.error || !exerciseData.isSelect) { resultsContainer.classList.add('hidden'); return; }
        resultsContainer.classList.remove('hidden');
        rowCount.textContent = `${result.rowCount} ${(window as any).__I18N__.rows}`;
        resultsHead.innerHTML = `<tr>${result.columns.map((c: string) =>
          `<th class="px-3 py-2 text-left border-b border-white/5">${c}</th>`
        ).join('')}</tr>`;
        const maxRows = Math.min(result.rows.length, 50);
        resultsBody.innerHTML = result.rows.slice(0, maxRows).map((row: any[]) =>
          `<tr class="border-b border-white/5 hover:bg-white/5">${row.map(cell =>
            `<td class="px-3 py-1.5 whitespace-nowrap">${cell ?? '<span class="text-slate-600">NULL</span>'}</td>`
          ).join('')}</tr>`
        ).join('');
        if (result.rows.length > 50) {
          resultsBody.innerHTML += `<tr><td colspan="${result.columns.length}" class="px-3 py-2 text-center text-slate-500 italic">... ${result.rows.length - 50} ${(window as any).__I18N__.moreRows}</td></tr>`;
        }
      }

      function showFeedback(success: boolean, message: string) {
        feedback.classList.remove('hidden');
        feedback.className = `mb-6 p-4 rounded-xl border ${success ? 'bg-emerald-900/10 border-emerald-500/30' : 'bg-red-900/10 border-red-500/30'}`;
        feedbackText.className = `text-sm font-medium ${success ? 'text-emerald-400' : 'text-red-400'}`;
        feedbackText.textContent = message;
      }

      function updateProgress() {
        const pct = (completed.size / exerciseData.total) * 100;
        progressBar.style.width = `${pct}%`;
        progressText.textContent = `${completed.size} / ${exerciseData.total}`;
      }

      function updateNavDots() {
        document.querySelectorAll('.nav-btn').forEach(btn => {
          const id = Number(btn.getAttribute('data-exercise-id'));
          if (completed.has(id)) {
            const dot = btn.querySelector('.status-dot');
            if (dot) { dot.classList.remove('bg-slate-700'); dot.classList.add('bg-emerald-500'); }
          }
        });
      }

      function updateNextButton() {
        if (!btnNext) return;
        if (currentSolved) {
          btnNext.classList.remove('bg-slate-800/50', 'text-slate-600', 'cursor-not-allowed', 'pointer-events-none');
          btnNext.classList.add('bg-slate-800', 'hover:bg-slate-700', 'text-slate-400');
        }
        // Also update mobile next button
        const btnNextMobile = document.getElementById('btn-next-mobile') as HTMLAnchorElement | null;
        if (btnNextMobile && currentSolved) {
          btnNextMobile.classList.remove('bg-slate-800/50', 'text-slate-600', 'cursor-not-allowed', 'pointer-events-none');
          btnNextMobile.classList.add('bg-slate-800', 'hover:bg-slate-700', 'text-slate-400');
        }
      }

      // Navigation guard for exercise links
      document.querySelectorAll('.nav-btn').forEach(link => {
        link.addEventListener('click', (e) => {
          const targetId = Number(link.getAttribute('data-exercise-id'));
          if (targetId === exerciseData.id) return;
          if (currentSolved || completed.has(targetId)) return;
          e.preventDefault();
          modalConfirm.href = (link as HTMLAnchorElement).href;
          skipModal.classList.remove('hidden');
          mobileMenu.classList.add('hidden');
        });
      });

      // Navigation guard for section intro links
      document.querySelectorAll('.section-link').forEach(link => {
        link.addEventListener('click', (e) => {
          if (currentSolved) return;
          e.preventDefault();
          modalConfirm.href = (link as HTMLAnchorElement).href;
          skipModal.classList.remove('hidden');
          mobileMenu.classList.add('hidden');
        });
      });

      modalCancel.onclick = () => skipModal.classList.add('hidden');
      skipModal.addEventListener('click', (e) => { if (e.target === skipModal) skipModal.classList.add('hidden'); });

      // Hint toggle (works for both mobile and desktop)
      document.getElementById('btn-hint')!.onclick = () => {
        const items = exerciseData.hint.split('\n').filter((s: string) => s.trim());
        const html = items.map((item: string) => `<li>${item.trim()}</li>`).join('');

        // Desktop hint
        const hintBoxD = document.getElementById('hint-box-desktop');
        const hintTextD = document.getElementById('hint-text-desktop');
        const hintPlaceholderD = document.getElementById('hint-placeholder-desktop');
        if (hintBoxD && hintTextD) {
          hintTextD.innerHTML = html;
          hintBoxD.classList.toggle('hidden');
          hintPlaceholderD?.classList.toggle('hidden');
        }

        // Mobile hint
        const hintBoxM = document.getElementById('hint-box-mobile');
        const hintTextM = document.getElementById('hint-text-mobile');
        if (hintBoxM && hintTextM) {
          hintTextM.innerHTML = html;
          hintBoxM.classList.toggle('hidden');
        }
      };

      document.getElementById('btn-run')?.addEventListener('click', runQuery);
      document.getElementById('btn-validate')!.onclick = validateCurrentQuery;
      document.getElementById('btn-reset')?.addEventListener('click', async () => {
        await resetDatabase();
        feedback.classList.add('hidden');
        resultsContainer.classList.add('hidden');
      });
      document.getElementById('btn-reset-mobile')?.addEventListener('click', async () => {
        await resetDatabase();
        feedback.classList.add('hidden');
        resultsContainer.classList.add('hidden');
      });

      // Theme toggle
      const btnTheme = document.getElementById('btn-theme')!;

      function applyTheme(theme: string) {
        if (theme === 'light') {
          document.documentElement.classList.add('light');
        } else {
          document.documentElement.classList.remove('light');
        }
      }

      const savedTheme = localStorage.getItem('sql-lab-theme') || 'dark';
      applyTheme(savedTheme);

      btnTheme.onclick = () => {
        const current = document.documentElement.classList.contains('light') ? 'light' : 'dark';
        const next = current === 'dark' ? 'light' : 'dark';
        localStorage.setItem('sql-lab-theme', next);
        applyTheme(next);
      };

      init();
    </script>
  </body>
</html>
