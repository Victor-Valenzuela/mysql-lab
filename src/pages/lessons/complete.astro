---
import "../../styles/global.css";
import t from "../../i18n/index.ts";

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<html lang={t.lang} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>SQL Lab — {t.complete.title}</title>
    <script is:inline>
      if (localStorage.getItem('sql-lab-theme') === 'light') document.documentElement.classList.add('light');
    </script>
  </head>

  <body class="bg-[#0f172a] text-slate-300 font-sans min-h-screen">
    <div class="min-h-screen flex items-center justify-center p-6">
      <div class="max-w-lg w-full text-center">
        <div class="inline-flex items-center justify-center w-24 h-24 bg-emerald-500/20 rounded-full mb-8">
          <svg class="w-12 h-12 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3h14l-1.5 6H6.5L5 3zM12 9v6m0 0l-3 3m3-3l3 3M8 21h8" />
          </svg>
        </div>

        <h1 class="text-4xl md:text-5xl font-black text-white tracking-tight mb-4">{t.complete.title}</h1>
        <p class="text-lg text-slate-400 font-semibold mb-6" set:html={t.complete.subtitle}></p>
        <p class="text-sm text-slate-400 leading-relaxed mb-8">{t.complete.message}</p>

        <div class="grid grid-cols-3 gap-4 mb-10 p-6 bg-slate-900/50 rounded-2xl border border-white/5">
          <div>
            <p id="completed-count" class="text-2xl font-black text-white">0</p>
            <p class="text-[10px] text-slate-500 uppercase tracking-widest">{t.complete.completed}</p>
          </div>
          <div>
            <p class="text-2xl font-black text-white">10</p>
            <p class="text-[10px] text-slate-500 uppercase tracking-widest">{t.complete.sections}</p>
          </div>
          <div>
            <p class="text-2xl font-black text-white">87</p>
            <p class="text-[10px] text-slate-500 uppercase tracking-widest">{t.welcome.exercises}</p>
          </div>
        </div>

        <div class="space-y-3 flex flex-col items-center">
          <a href={base} class="inline-block px-8 py-3 bg-emerald-600 hover:bg-emerald-500 text-white font-bold rounded-xl transition-all shadow-lg shadow-emerald-500/20 text-sm uppercase tracking-widest text-center">
            {t.complete.backToStart}
          </a>
          <button id="btn-reset" class="inline-block px-8 py-3 bg-slate-800 hover:bg-slate-700 text-slate-400 text-xs rounded-xl transition-all border border-white/10 uppercase tracking-widest">
            {t.complete.resetAndRepeat}
          </button>
        </div>
      </div>
    </div>

    <div id="reset-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-sm">
      <div class="bg-[#1e293b] border border-white/10 rounded-2xl p-6 max-w-sm w-full mx-4 shadow-2xl">
        <p class="text-white font-bold mb-2">{t.modal.resetTitle}</p>
        <p class="text-sm text-slate-400 mb-5">{t.modal.resetMessage}</p>
        <div class="flex gap-3 justify-end">
          <button id="reset-cancel" class="px-4 py-2 text-sm text-slate-400 hover:text-white transition">{t.modal.cancel}</button>
          <button id="reset-confirm" class="px-4 py-2 bg-red-600 hover:bg-red-500 text-white text-sm font-bold rounded-lg transition">{t.modal.reset}</button>
        </div>
      </div>
    </div>

    <script define:vars={{ base }}>
      window.__BASE__ = base;
    </script>

    <script>
      const base = (window as any).__BASE__;
      const savedTheme = localStorage.getItem('sql-lab-theme') || 'dark';
      if (savedTheme === 'light') document.documentElement.classList.add('light');

      const completed = JSON.parse(localStorage.getItem('sql-lab-completed') || '[]');
      document.getElementById('completed-count')!.textContent = String(completed.length);

      document.getElementById('btn-reset')!.onclick = () => {
        document.getElementById('reset-modal')!.classList.remove('hidden');
      };
      document.getElementById('reset-cancel')!.onclick = () => {
        document.getElementById('reset-modal')!.classList.add('hidden');
      };
      document.getElementById('reset-confirm')!.onclick = () => {
        localStorage.removeItem('sql-lab-completed');
        window.location.href = base;
      };
    </script>
  </body>
</html>
