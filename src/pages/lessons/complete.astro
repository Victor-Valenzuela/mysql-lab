---
import "../../styles/global.css";

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>SQL Lab — ¡Completado!</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <script is:inline>
      if (localStorage.getItem('sql-lab-theme') === 'light') document.documentElement.classList.add('light');
    </script>
  </head>

  <body class="bg-[#0f172a] text-slate-300 font-sans min-h-screen">
    <div class="min-h-screen flex items-center justify-center p-6">
      <div class="max-w-lg w-full text-center">
        <!-- Trophy icon -->
        <div class="inline-flex items-center justify-center w-24 h-24 bg-emerald-500/20 rounded-full mb-8">
          <svg class="w-12 h-12 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3h14l-1.5 6H6.5L5 3zM12 9v6m0 0l-3 3m3-3l3 3M8 21h8" />
          </svg>
        </div>

        <!-- Title -->
        <h1 class="text-4xl md:text-5xl font-black text-white tracking-tight mb-4">
          ¡Felicidades!
        </h1>
        <p class="text-lg text-emerald-400 font-semibold mb-6">Completaste SQL<span class="text-white">_Lab</span></p>

        <!-- Message -->
        <p class="text-sm text-slate-400 leading-relaxed mb-8">
          Has dominado los fundamentos de MySQL: desde crear tablas hasta gestionar permisos, pasando por consultas complejas, JOINs, subconsultas y optimización. Ahora tienes las herramientas para trabajar con bases de datos reales.
        </p>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-4 mb-10 p-6 bg-slate-900/50 rounded-2xl border border-white/5">
          <div>
            <p id="completed-count" class="text-2xl font-black text-white">0</p>
            <p class="text-[10px] text-slate-500 uppercase tracking-widest">Completados</p>
          </div>
          <div>
            <p class="text-2xl font-black text-white">10</p>
            <p class="text-[10px] text-slate-500 uppercase tracking-widest">Secciones</p>
          </div>
          <div>
            <p class="text-2xl font-black text-white">87</p>
            <p class="text-[10px] text-slate-500 uppercase tracking-widest">Ejercicios</p>
          </div>
        </div>

        <!-- Actions -->
        <div class="space-y-3">
          <a href={base} class="block w-full px-8 py-3 bg-emerald-600 hover:bg-emerald-500 text-white font-bold rounded-xl transition-all shadow-lg shadow-emerald-500/20 text-sm uppercase tracking-widest text-center">
            Volver al inicio
          </a>
          <button id="btn-reset" class="w-full px-8 py-3 bg-slate-800 hover:bg-slate-700 text-slate-400 text-xs rounded-xl transition-all border border-white/10 uppercase tracking-widest">
            Reiniciar progreso y repetir
          </button>
        </div>
      </div>
    </div>

    <!-- Reset confirmation modal -->
    <div id="reset-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-sm">
      <div class="bg-[#1e293b] border border-white/10 rounded-2xl p-6 max-w-sm w-full mx-4 shadow-2xl">
        <p class="text-white font-bold mb-2">¿Reiniciar todo el progreso?</p>
        <p class="text-sm text-slate-400 mb-5">Se borrarán todos los ejercicios completados y volverás a empezar desde cero.</p>
        <div class="flex gap-3 justify-end">
          <button id="reset-cancel" class="px-4 py-2 text-sm text-slate-400 hover:text-white transition">Cancelar</button>
          <button id="reset-confirm" class="px-4 py-2 bg-red-600 hover:bg-red-500 text-white text-sm font-bold rounded-lg transition">Reiniciar</button>
        </div>
      </div>
    </div>

    <script define:vars={{ base }}>
      window.__BASE__ = base;
    </script>

    <script>
      const base = (window as any).__BASE__;

      // Theme
      const savedTheme = localStorage.getItem('sql-lab-theme') || 'dark';
      if (savedTheme === 'light') document.documentElement.classList.add('light');

      // Show completed count
      const completed = JSON.parse(localStorage.getItem('sql-lab-completed') || '[]');
      document.getElementById('completed-count')!.textContent = String(completed.length);

      // Reset
      document.getElementById('btn-reset')!.onclick = () => {
        document.getElementById('reset-modal')!.classList.remove('hidden');
      };
      document.getElementById('reset-cancel')!.onclick = () => {
        document.getElementById('reset-modal')!.classList.add('hidden');
      };
      document.getElementById('reset-confirm')!.onclick = () => {
        localStorage.removeItem('sql-lab-completed');
        window.location.href = base;
      };
    </script>
  </body>
</html>
