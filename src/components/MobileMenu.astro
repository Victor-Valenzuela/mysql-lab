---
import Sidebar from "./Sidebar.astro";
import t from "../i18n/index.ts";

const { base = '/', currentExerciseId = null, currentCategoryId = null } = Astro.props;
---

<div id="mobile-menu" class="hidden fixed inset-0 z-[90] lg:hidden">
  <div id="menu-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
  <aside class="absolute left-0 top-0 bottom-0 w-72 bg-[#0a0f1e] border-r border-white/5 overflow-y-auto p-6 pt-6">
    <a href={base} class="flex items-center gap-3 mb-6 px-3 py-2 rounded-lg hover:bg-white/5 transition">
      <div class="w-6 h-6 bg-emerald-500/20 rounded flex items-center justify-center">
        <svg class="w-3 h-3 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3" />
        </svg>
      </div>
      <span class="text-xs text-slate-300 font-medium">{t.nav.backToStart}</span>
    </a>
    <Sidebar base={base} currentExerciseId={currentExerciseId} currentCategoryId={currentCategoryId} />
  </aside>
</div>
